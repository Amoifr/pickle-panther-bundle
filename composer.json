{
    "name": "amoifr/pickle-panther-bundle",
    "description": "YAML-driven E2E testing engine for Symfony on top of Panther: write browser scenarios in (FR/EN) near-natural language, mapped to PHP sentences, with an HTML report.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "keywords": ["symfony", "panther", "e2e", "testing", "bdd", "yaml"],
    "authors": [
        {
            "name": "Pascal CESCON",
            "email": "pascal.cescon@gmail.com",
            "homepage": "https://github.com/Amoifr"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-dom": "*",
        "symfony/framework-bundle": "^7.1 || ^8.0",
        "symfony/panther": "^2.2",
        "symfony/yaml": "^7.1 || ^8.0",
        "symfony/css-selector": "^7.1 || ^8.0",
        "symfony/browser-kit": "^7.1 || ^8.0",
        "symfony/config": "^7.1 || ^8.0",
        "symfony/dependency-injection": "^7.1 || ^8.0",
        "symfony/http-kernel": "^7.1 || ^8.0",
        "php-webdriver/webdriver": "^1.15",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "require-dev": {
        "symfony/dotenv": "^7.1 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Amoifr\\PicklePantherBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amoifr\\PicklePantherBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    }
}
